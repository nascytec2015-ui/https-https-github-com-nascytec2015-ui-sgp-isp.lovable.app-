generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tecnico {
  id           String   @id @default(uuid())
  nome         String
  telefone     String?
  email        String?
  cargo        String?
  equipe       String?
  foto         String?
  assinatura   String?
  ativo        Boolean  @default(true)

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  ordens       OrdemServico[]
}

model OrdemServico {
  id           String   @id @default(uuid())

  clienteId    String
  tecnicoId    String?

  status       String
  prioridade   String?
  descricao    String?

  abertura     DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  tecnico       Tecnico?      @relation(fields: [tecnicoId], references: [id])

  materiais     OSMaterial[]
  evidencias    OSEvidencia[]

  @@index([clienteId])
  @@index([tecnicoId])
}

model OSEvidencia {
  id           String   @id @default(uuid())

  osId         String

  tipo         String
  arquivo      String
  descricao    String?

  latitude     Float?
  longitude    Float?

  created_at   DateTime @default(now())

  ordem        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@index([osId])
}

enum OsTipo {
  INSTALACAO
  MANUTENCAO
  SUPORTE
  VISITA_TECNICA
  MUDANCA_ENDERECO
  CANCELAMENTO
}

model Cliente {
  id          String   @id @default(uuid())
  nome        String
  cpfCnpj     String? 
  telefone    String?
  email       String?
  endereco    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ordensServico OrdemServico[]
}

model OSMaterial {
  id              String @id @default(uuid())
  ordemServicoId  String
  nome            String
  quantidade      Int @default(1)

  ordemServico    OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
}



